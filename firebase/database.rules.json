{
  "rules": {

    // ════════════════════════════════════════════════════════
    //  REPORTS
    // ════════════════════════════════════════════════════════
    "reports": {
      ".read": "auth != null",
      ".indexOn": ["status", "timestamp", "reporterId", "approved", "type"],
      "$reportId": {
        ".write": "auth != null && (
          !data.exists() && (
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager' ||
            root.child('users').child(auth.uid).child('approved').val() === true
          ) ||
          data.exists() && (
            data.child('reporterId').val() === auth.uid ||
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager'
          )
        )",
        ".validate": "newData.hasChildren(['personName', 'reporterId', 'timestamp', 'type'])",
        "status": {
          ".write": "auth != null && (
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager' &&
            root.child('users').child(auth.uid).child('permissions').child('canApproveReports').val() === true
          )"
        }
      }
    },

    // ════════════════════════════════════════════════════════
    //  FOUND PERSONS
    // ════════════════════════════════════════════════════════
    "found_persons": {
      ".read": "auth != null",
      ".indexOn": ["status", "timestamp", "reporterId"],
      "$id": {
        ".write": "auth != null && (
          !data.exists() && (
            root.child('users').child(auth.uid).child('approved').val() === true ||
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager'
          ) ||
          data.exists() && (
            data.child('reporterId').val() === auth.uid ||
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager'
          )
        )"
      }
    },

    // ════════════════════════════════════════════════════════
    //  SIGHTINGS — مشاهدات
    // ════════════════════════════════════════════════════════
    "sightings": {
      ".read": "auth != null",
      ".indexOn": ["timestamp", "reporterId", "status"],
      "$id": {
        ".write": "auth != null"
      }
    },

    // ════════════════════════════════════════════════════════
    //  MATCHES
    // ════════════════════════════════════════════════════════
    "matches": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      ".write": "auth != null",
      ".indexOn": ["status", "timestamp", "reportId", "similarity"]
    },

    // ════════════════════════════════════════════════════════
    //  HUMAN REVIEW QUEUE
    // ════════════════════════════════════════════════════════
    "review_queue": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      ".write": "auth != null",
      ".indexOn": ["status", "timestamp", "similarity"]
    },

    // ════════════════════════════════════════════════════════
    //  USERS
    // ════════════════════════════════════════════════════════
    "users": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      "$uid": {
        ".read": "auth != null && (
          $uid === auth.uid ||
          root.child('users').child(auth.uid).child('role').val() === 'admin' ||
          root.child('users').child(auth.uid).child('role').val() === 'manager'
        )",
        ".write": "auth != null && (
          $uid === auth.uid ||
          root.child('users').child(auth.uid).child('role').val() === 'admin' ||
          root.child('users').child(auth.uid).child('role').val() === 'manager' &&
          root.child('users').child(auth.uid).child('permissions').child('canManageMembers').val() === true
        )",
        "role": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "permissions": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
        },
        "banned": {
          ".write": "auth != null && (
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager' &&
            root.child('users').child(auth.uid).child('permissions').child('canBanUsers').val() === true
          )"
        },
        "approved": {
          ".write": "auth != null && (
            root.child('users').child(auth.uid).child('role').val() === 'admin' ||
            root.child('users').child(auth.uid).child('role').val() === 'manager' &&
            root.child('users').child(auth.uid).child('permissions').child('canManageMembers').val() === true
          )"
        }
      }
    },

    // ════════════════════════════════════════════════════════
    //  NOTIFICATIONS
    // ════════════════════════════════════════════════════════
    "notifications": {
      "$uid": {
        ".read": "auth != null && (
          $uid === auth.uid ||
          root.child('users').child(auth.uid).child('role').val() === 'admin'
        )",
        ".write": "auth != null && (
          $uid === auth.uid ||
          root.child('users').child(auth.uid).child('role').val() === 'admin' ||
          root.child('users').child(auth.uid).child('role').val() === 'manager' &&
          root.child('users').child(auth.uid).child('permissions').child('canSendNotifications').val() === true
        )"
      }
    },

    // ════════════════════════════════════════════════════════
    //  ADMIN NOTIFICATIONS
    // ════════════════════════════════════════════════════════
    "admin_notifications": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      ".write": "auth != null"
    },

    // ════════════════════════════════════════════════════════
    //  CHATS & MESSAGES
    // ════════════════════════════════════════════════════════
    "chats": {
      "$chatId": {
        ".read": "auth != null && (
          $chatId.contains(auth.uid) ||
          root.child('users').child(auth.uid).child('role').val() === 'admin' ||
          root.child('users').child(auth.uid).child('role').val() === 'manager'
        )",
        ".write": "auth != null && (
          $chatId.contains(auth.uid) ||
          root.child('users').child(auth.uid).child('role').val() === 'admin'
        )"
      }
    },
    "messages": {
      "$chatId": {
        ".read": "auth != null && (
          root.child('chats').child($chatId).child('user1').val() === auth.uid ||
          root.child('chats').child($chatId).child('user2').val() === auth.uid
        )",
        "$msgId": {
          ".write": "auth != null && (
            root.child('chats').child($chatId).child('user1').val() === auth.uid ||
            root.child('chats').child($chatId).child('user2').val() === auth.uid
          )"
        }
      }
    },

    // ════════════════════════════════════════════════════════
    //  UNREAD COUNTS
    // ════════════════════════════════════════════════════════
    "unread_counts": {
      "$uid": {
        ".read": "auth != null && $uid === auth.uid",
        ".write": "auth != null && $uid === auth.uid"
      }
    },

    // ════════════════════════════════════════════════════════
    //  REPORT UPDATES (timeline)
    // ════════════════════════════════════════════════════════
    "report_updates": {
      ".read": "auth != null",
      ".write": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )"
    },

    // ════════════════════════════════════════════════════════
    //  ABUSE REPORTS
    // ════════════════════════════════════════════════════════
    "abuse_reports": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      ".write": "auth != null",
      ".indexOn": ["timestamp", "status"]
    },

    // ════════════════════════════════════════════════════════
    //  PENDING APPROVALS
    // ════════════════════════════════════════════════════════
    "pending_approvals": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      ".write": "auth != null"
    },

    // ════════════════════════════════════════════════════════
    //  AMBER ALERTS
    // ════════════════════════════════════════════════════════
    "amber_alerts": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },

    // ════════════════════════════════════════════════════════
    //  LEADERBOARD
    // ════════════════════════════════════════════════════════
    "leaderboard": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    // ════════════════════════════════════════════════════════
    //  SUCCESS STORIES
    // ════════════════════════════════════════════════════════
    "success_stories": {
      ".read": "auth != null",
      ".write": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )"
    },

    // ════════════════════════════════════════════════════════
    //  APP SETTINGS / STATS
    // ════════════════════════════════════════════════════════
    "app_settings": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "settings": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "stats_cache": {
      ".read": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )",
      ".write": "auth != null && (
        root.child('users').child(auth.uid).child('role').val() === 'admin' ||
        root.child('users').child(auth.uid).child('role').val() === 'manager'
      )"
    }
  }
}
