<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    android:fitsSystemWindows="true">

    <!-- Guest banner -->
    <TextView
        android:id="@+id/tv_guest_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:gravity="center"
        android:background="@color/md_primary_container"
        android:textColor="@color/md_on_primary_container"
        android:textSize="13sp"
        android:text="@string/guest_banner"
        android:visibility="gone"/>

    <!-- Notification / Offline banner — قابل للإغلاق -->
    <LinearLayout
        android:id="@+id/tv_offline_pending"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#D32F2F"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_notif_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:gravity="center"/>

        <!-- زر فتح الإشعارات -->
        <TextView
            android:id="@+id/btn_notif_open"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="فتح"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="@color/md_primary"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp"/>

        <!-- زر إغلاق -->
        <TextView
            android:id="@+id/btn_notif_dismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:paddingStart="8dp"
            android:paddingEnd="6dp"
            android:paddingVertical="4dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingHorizontal="16dp"
            android:paddingBottom="120dp">

            <!-- ── Header: Welcome + Points ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_title"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/tv_user_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@color/md_primary_container"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="5dp"
                    android:textSize="12sp"
                    android:textColor="@color/md_on_primary_container"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- ── Row 1: Browse + Map ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_browse"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/md_surface"
                    app:strokeColor="@color/md_outline_variant"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_search_person"
                            app:tint="@color/md_primary"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تصفح الحالات"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_on_surface"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_map"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/md_primary_container"
                    app:strokeWidth="0dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_map"
                            app:tint="@color/md_primary"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="خريطة المفقودين"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_on_primary_container"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Row 2: Profile ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_profile"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/md_surface"
                    app:strokeColor="@color/md_outline_variant"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/md_primary"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حسابي"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/md_on_surface"
                            android:gravity="center"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Row 3: Stats + Leaderboard ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_statistics"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/md_surface_container_low"
                    app:strokeColor="@color/md_outline_variant"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_result"
                            app:tint="@color/md_on_surface_variant"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="إحصائيات"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/md_on_surface_variant"
                            android:layout_marginTop="5dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_leaderboard"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/md_tertiary_container"
                    app:strokeWidth="0dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_result"
                            app:tint="@color/md_on_tertiary_container"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الأوائل"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/md_on_tertiary_container"
                            android:layout_marginTop="5dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Success Stories Row -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_success_stories"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/color_found_container"
                app:strokeWidth="0dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_found"
                        app:tint="@color/color_found"
                        android:contentDescription="@null"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="قصص النجاح"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_found"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حالات تم العثور عليها بفضل مجتمعنا"
                            android:textSize="12sp"
                            android:textColor="@color/color_found"
                            android:alpha="0.8"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/color_found"
                        android:contentDescription="@null"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Advanced Search Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_advanced_search"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/btn_advanced_search"
                android:textSize="14sp"
                app:icon="@drawable/ic_search_face"
                app:iconGravity="textStart"
                android:layout_marginBottom="8dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_report"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="80dp"
        android:text="إضافة بلاغ"
        app:icon="@drawable/ic_camera"
        app:backgroundTint="@color/md_primary"
        android:textColor="@color/md_on_primary"
        app:iconTint="@color/md_on_primary"/>

    <!-- Ad Banner -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-3940256099942544/6300978111"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
