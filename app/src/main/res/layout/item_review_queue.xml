<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:layoutDirection="rtl"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:strokeColor="@color/md_outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Name + Similarity badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Person icon -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_person_outline"
                app:tint="?attr/colorPrimary"
                android:background="@color/md_primary_container"
                android:padding="8dp"
                android:contentDescription="@null" />

            <!-- Name + ID column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_review_person_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اسم الشخص"
                    style="?attr/textAppearanceTitleSmall"
                    android:textColor="?attr/colorOnSurface"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tv_review_ids"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="معرف: —"
                    style="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1" />

            </LinearLayout>

            <!-- Similarity badge -->
            <TextView
                android:id="@+id/tv_review_similarity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00%"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textStyle="bold"
                style="?attr/textAppearanceLabelLarge"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_card_rounded" />

        </LinearLayout>

        <!-- Row 2: Type chip + Timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_review_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رؤية"
                style="@style/Widget.Material3.Chip.Assist"
                android:checkable="false"
                app:chipMinHeight="28dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_review_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00/00 00:00"
                style="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md_outline_variant"
            android:layout_marginBottom="12dp" />

        <!-- Row 3: Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_review_approve"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="قبول"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/success_color"
                app:icon="@drawable/ic_check_circle_green"
                app:iconTint="@android:color/white"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_review_reject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="رفض"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/md_error"
                app:icon="@drawable/ic_warning_outline"
                app:iconTint="@android:color/white"
                app:cornerRadius="10dp"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
