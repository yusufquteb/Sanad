<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- رأس الويدجت -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔍 المفقودون"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_btn_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="عرض الكل ›"
            android:textColor="#AED6F1"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- فاصل -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- حالة 1 -->
    <LinearLayout
        android:id="@+id/widget_row1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_name1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/widget_addr1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="11sp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/widget_date1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AED6F1"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- حالة 2 -->
    <LinearLayout
        android:id="@+id/widget_row2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_name2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/widget_addr2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="11sp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/widget_date2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AED6F1"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- حالة 3 -->
    <LinearLayout
        android:id="@+id/widget_row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_name3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/widget_addr3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="11sp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/widget_date3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AED6F1"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>
