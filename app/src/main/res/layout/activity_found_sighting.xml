<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_surface"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_found_sighting"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="شُفت شخصاً"
            android:background="@color/md_surface"
            app:navigationIconTint="@color/md_on_surface"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/md_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="120dp">

            <!-- Info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_tertiary_container"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="رأيت شخصاً مجهولاً؟"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_on_tertiary_container"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="التقط صورته وسنبحث في قاعدة البيانات تلقائياً"
                        android:textSize="13sp"
                        android:textColor="@color/md_on_tertiary_container"
                        android:alpha="0.85"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Photo preview -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_sighting_photo"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/md_outline_variant"
                app:strokeWidth="1dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">
                <ImageView
                    android:id="@+id/iv_sighting_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="صورة الشخص"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Camera / Gallery buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sighting_camera"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="كاميرا"
                    android:layout_marginEnd="6dp"
                    app:icon="@drawable/ic_camera"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sighting_gallery"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="معرض"
                    android:layout_marginStart="6dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <!-- Match result -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_secondary_container"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:id="@+id/tv_sighting_match_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_secondary_container"
                    android:visibility="gone"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- ملاحظة سريعة (بدلاً من الوصف الكامل — AI يتولى المطابقة) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="📝 ملاحظة سريعة (لون الملابس، الحالة...)"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_sighting_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="1"
                    android:maxLines="3"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Location -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="الموقع التفصيلي (شارع، منطقة...)"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="12dp"
                app:startIconDrawable="@drawable/ic_map"
                app:startIconTint="@color/md_primary">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_sighting_location"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Governorate spinner (Material style) -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="المحافظة"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_marginBottom="20dp">
                <Spinner
                    android:id="@+id/sp_sighting_governorate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_spinner_outlined"
                    android:padding="16dp"/>
            </com.google.android.material.textfield.TextInputLayout>


            <!-- ─── ربط بكود بلاغ موجود ─── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/md_primary_container"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔗 هل رأيت شخصاً مفقوداً بعينه؟"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_on_primary_container"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:hint="كود البلاغ (مثال: RPT-12345)"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_marginEnd="8dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_linked_report_code"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:singleLine="true"
                                android:imeOptions="actionDone"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_link_report"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:text="ربط"
                            style="@style/Widget.Material3.Button"
                            app:cornerRadius="10dp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_linked_report_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/md_on_primary_container"
                        android:layout_marginTop="6dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Progress -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_sighting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:layout_marginBottom="8dp"
                app:indicatorColor="@color/md_primary"
                app:trackColor="@color/md_surface_variant"/>

            <!-- Status -->
            <TextView
                android:id="@+id/tv_sighting_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/md_on_surface_variant"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- Submit -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sighting_submit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="إرسال البلاغ"
                android:textSize="15sp"
                android:textStyle="bold"
                style="@style/Widget.Material3.Button"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
