<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_my_reports"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="بلاغاتي"
            app:navigationIconTint="?attr/colorOnSurface"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="120dp">

            <!-- شرح الصفحة -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/md_primary_container"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋"
                        android:textSize="28sp"
                        android:layout_marginEnd="12dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="بلاغاتي"
                            style="?attr/textAppearanceTitleMedium" 
                            android:textStyle="bold"
                            android:textColor="@color/md_on_primary_container"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تابع حالة كل بلاغ رفعته"
                            style="?attr/textAppearanceBodyMedium" 
                            android:textColor="@color/md_on_primary_container"
                            android:alpha="0.8"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- تبويبات: بلاغاتي / المفضلة -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_my_tabs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_my_reports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋 بلاغاتي"
                    android:checked="true"
                    style="@style/Widget.Material3.Chip.Filter"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bookmarks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔖 المفضلة"
                    style="@style/Widget.Material3.Chip.Filter"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- loading -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_my_reports"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"/>

            <!-- empty state -->
            <TextView
                android:id="@+id/tv_my_reports_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="لم ترفع أي بلاغ بعد"
                android:gravity="center"
                style="?attr/textAppearanceTitleMedium" 
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="60dp"
                android:visibility="gone"/>

            <!-- القائمة — بلاغاتي -->
            <LinearLayout
                android:id="@+id/layout_my_reports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- قائمة المفضلة -->
            <LinearLayout
                android:id="@+id/layout_bookmarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
