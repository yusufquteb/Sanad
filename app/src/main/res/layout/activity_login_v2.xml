<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:layoutDirection="rtl">

    <!-- ══ LOGO SECTION - gradient أزرق ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_home_header">

        <!-- دائرة بيضاء شبه شفافة -->
        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="18dp">

            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/bg_login_logo_circle"/>

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_search_person"
                app:tint="#FFFFFF"
                android:contentDescription="@null"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سند | Sanad"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="0.02"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مش لوحدك"
            android:textSize="14sp"
            android:textColor="#BBFFFFFF"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.04"/>
    </LinearLayout>

    <!-- ══ FORM SECTION ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="مرحباً 👋"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1B2A6B"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سجّل دخولك للوصول لكل الميزات"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="28dp"/>

        <!-- زر Google -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_google_signin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="تسجيل الدخول بـ Google"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1B2A6B"
            app:backgroundTint="#FFFFFF"
            app:strokeColor="#E8EAFF"
            app:strokeWidth="2dp"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="22dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_marginBottom="14dp"
            android:elevation="2dp"/>

        <!-- زر الزائر -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guest"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🚶 الدخول كزائر"
            android:textSize="14sp"
            android:textColor="#666666"
            app:backgroundTint="#F5F7FA"
            app:cornerRadius="16dp"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_marginBottom="24dp"/>

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#1565C0"/>

        <!-- شريط تحذير -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_warning_strip"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="التطبيق مجاني تماماً — لا تدفع أموالاً لأحد"
                android:textSize="12sp"
                android:textColor="#E65100"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ══ FOOTER ══ -->
    <TextView
        android:id="@+id/tv_disclaimer_link"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 الشروط والأحكام والخصوصية"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:gravity="center"
        android:paddingBottom="20dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
