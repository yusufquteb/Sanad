<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_profile_rank_card.xml  [Phase 3 - إعادة تصميم]
    ─────────────────────────────────────────────────────
    الكارد الثاني في البروفايل — مطابق لتصميم الكروت التالية:
    • نفس الـ corners (16dp) والـ elevation (0dp)
    • نفس الـ margin (16dp أفقي + 8dp فوق)
    • border لطيف مثل الكروت الأخرى
    • مسافة 8dp فوقه لإبعاده عن الكارد الأول
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E8E8E8"
    app:strokeWidth="1dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- عنوان القسم -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الرتبة والنقاط"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="12dp"/>

        <!-- الرتبة الحالية -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/tv_rank_emoji"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:text="🟢"
                android:textSize="22sp"
                android:gravity="center"
                android:background="@drawable/bg_qa_blue"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_rank_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عضو"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#1a1a1a"/>

                <TextView
                    android:id="@+id/tv_rank_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 نقطة"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_points_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 pts"
                android:textStyle="bold"
                android:textSize="12sp"
                app:chipBackgroundColor="#EEF2FF"
                android:textColor="#1565C0"
                app:chipMinTouchTargetSize="0dp"
                app:chipCornerRadius="16dp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F5F5F5" android:layout_marginVertical="8dp"/>

        <!-- Progress bar نحو الرتبة التالية -->
        <TextView
            android:id="@+id/tv_rank_next_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="التقدم نحو الرتبة التالية"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_rank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            app:trackCornerRadius="4dp"
            app:trackColor="#F0F0F0"
            app:indicatorColor="#1565C0"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_rank_current_pts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0"
                android:textSize="10sp"
                android:textColor="#AAAAAA"/>

            <TextView
                android:id="@+id/tv_rank_target_pts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500"
                android:textSize="10sp"
                android:textColor="#AAAAAA"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F5F5F5" android:layout_marginBottom="12dp"/>

        <!-- إحصائيات سريعة — نفس تصميم باقي الأقسام -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_my_reports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بلاغاتي"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="36dp"
                android:background="#F0F0F0"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_matched"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تطابقات"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="36dp"
                android:background="#F0F0F0"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_resolved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#F57C00"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مُحلّة"
                    android:textSize="11sp"
                    android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
