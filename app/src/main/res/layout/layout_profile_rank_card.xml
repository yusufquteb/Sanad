<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_profile_rank_card.xml
    [مرحلة 7.5] بطاقة الرتبة والنقاط مع progress bar
    تُضاف في activity_profile.xml بعد بطاقة الإحصائيات.

    الاستخدام في ProfileActivity:
      <include layout="@layout/layout_profile_rank_card"
               android:id="@+id/rank_card"/>

    في الكود يُحدَّث عبر ProfileActivity.updateRankCard()
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- الرتبة الحالية -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tv_rank_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟢"
                android:textSize="28sp"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_rank_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عضو"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface"
                    style="?attr/textAppearanceTitleSmall"/>

                <TextView
                    android:id="@+id/tv_rank_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 نقطة"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- شارة النقاط -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_points_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 pts"
                android:textStyle="bold"
                android:textSize="12sp"
                app:chipBackgroundColor="?attr/colorPrimaryContainer"
                android:textColor="?attr/colorOnPrimaryContainer"
                app:chipMinTouchTargetSize="0dp"
                app:chipCornerRadius="16dp"/>
        </LinearLayout>

        <!-- Progress bar نحو الرتبة التالية -->
        <TextView
            android:id="@+id/tv_rank_next_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="التقدم نحو الرتبة التالية"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="6dp"/>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_rank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            app:trackCornerRadius="4dp"
            app:trackColor="?attr/colorSurfaceVariant"
            app:indicatorColor="?attr/colorPrimary"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_rank_current_pts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <TextView
                android:id="@+id/tv_rank_target_pts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <!-- إحصائيات سريعة -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <!-- بلاغاتي -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_my_reports"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بلاغاتي"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- تطابقات مؤكدة -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_matched"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_found"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تطابقات"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="36dp"
                android:background="?attr/colorOutlineVariant"/>

            <!-- حالات مغلقة -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_resolved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_resolved"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="مُحلّة"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
