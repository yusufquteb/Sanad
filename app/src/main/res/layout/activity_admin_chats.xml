<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ══════════════════════════════════════
         AppBar
         ══════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_admin_chats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_admin_chats"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="محادثات المستخدمين"
            app:titleCentered="true"
            app:navigationIconTint="?attr/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════
         Main Content
         ══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ── Stats Card (redesigned, proper corners) ── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_chats_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Chat Icon Badge -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_chat_bubble"
                        app:tint="?attr/colorPrimary"
                        android:contentDescription="@null" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Stats Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إجمالي المحادثات"
                        style="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView
                        android:id="@+id/tv_admin_chats_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="جارٍ التحميل..."
                        style="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Search Bar ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_search_chats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:startIconDrawable="@drawable/ic_search_outline"
            app:startIconTint="?attr/colorOnSurfaceVariant"
            app:hintTextColor="?attr/colorOnSurfaceVariant"
            android:hint="بحث باسم المستخدم..."
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search_chats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:textDirection="rtl"
                android:gravity="end" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Progress Indicator ── -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_admin_chats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            app:trackCornerRadius="0dp" />

        <!-- ── Empty State ── -->
        <LinearLayout
            android:id="@+id/layout_empty_chats"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_chat_bubble"
                app:tint="?attr/colorOnSurfaceVariant"
                android:alpha="0.35"
                android:contentDescription="@null"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/tv_empty_admin_chats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لا توجد محادثات بعد"
                style="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ستظهر هنا عند بدء المستخدمين للتواصل"
                style="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />
        </LinearLayout>

        <!-- ── RecyclerView ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_admin_chats"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
