<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="بحث متقدم"
            android:background="@color/md_surface"
            app:navigationIconTint="@color/md_on_surface"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:startIconDrawable="@drawable/ic_search_person"
            app:startIconTint="@color/md_primary"
            android:hint="ابحث بالاسم أو الموقع...">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_filter_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </com.google.android.material.textfield.TextInputLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Filter chips section -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/md_surface">

                <!-- Gender chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الجنس"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_filter_male"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ذكر"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_filter_female"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أنثى"
                        style="@style/Widget.Material3.Chip.Filter"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Age chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الفئة العمرية"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_age_child"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="طفل (0-12)"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_age_teen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مراهق (13-17)"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_age_young"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="شاب (18-35)"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_age_adult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بالغ (36-60)"
                        style="@style/Widget.Material3.Chip.Filter"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_age_old"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="كبير (+60)"
                        style="@style/Widget.Material3.Chip.Filter"/>
                </com.google.android.material.chip.ChipGroup>

                <!-- Governorate chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المحافظة"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginBottom="6dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_governorate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:chipSpacingHorizontal="6dp"
                        app:chipSpacingVertical="6dp"/>

                </HorizontalScrollView>

                <!-- Reset button added to match your Java code -->
<com.google.android.material.button.MaterialButton
    android:id="@+id/btn_reset_filters"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="إعادة تعيين"
    style="@style/Widget.Material3.Button.TextButton"
    android:layout_marginBottom="8dp"/>
                <!-- Search button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_filter_search"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="بحث الآن"
                    android:textSize="14sp"
                    style="@style/Widget.Material3.Button"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/md_outline_variant"/>

        <!-- Results count + progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:background="@color/md_background">

            <TextView
                android:id="@+id/tv_filter_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/md_on_surface_variant"
                android:text="ادخل كلمة البحث أو اختر فلتراً"/>

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_filter"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorSize="24dp"
                app:trackThickness="3dp"
                app:indicatorColor="@color/md_primary"
                app:trackColor="@color/md_surface_variant"/>
        </LinearLayout>

        <!-- Empty state -->
        <TextView
            android:id="@+id/tv_filter_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="لا توجد نتائج"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="@color/md_on_surface_variant"
            android:padding="32dp"
            android:visibility="gone"/>

        <!-- Results list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_filter_results"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
