<?xml version="1.0" encoding="utf-8"?>
<!--
  item_abuse_report.xml — بطاقة بلاغ سوء الاستخدام
  ✅ Material 3 color tokens فقط (لا hex hardcoded)
  ✅ M3 Button styles (Tonal / Outlined / Text+Error)
  ✅ لا إيموجي في النصوص
  ✅ Details box داخل card منفصل للـ contrast
  ✅ Reporter + Time في صف واحد مع icons خفيفة
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── الصف العلوي: أيقونة + اسم المُبلَّغ عنه + Chip الحالة ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- أيقونة تحذير كـ badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="?attr/colorErrorContainer"
                app:cardElevation="0dp"
                android:layout_marginEnd="12dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_warning_outline"
                    app:tint="?attr/colorOnErrorContainer"
                    android:contentDescription="@null" />
            </com.google.android.material.card.MaterialCardView>

            <!-- اسم المُبلَّغ عنه -->
            <TextView
                android:id="@+id/tv_abuse_target"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Chip الحالة -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_abuse_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="جديد"
                style="@style/Widget.Material3.Chip.Assist"
                app:chipMinTouchTargetSize="0dp"
                android:clickable="false"
                android:focusable="false"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- ── السبب ── -->
        <TextView
            android:id="@+id/tv_abuse_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp" />

        <!-- ── التفاصيل (خلفية متباينة) ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tv_abuse_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:padding="10dp"
                android:lineSpacingMultiplier="1.5" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ── المُبلِّغ + الوقت في صف واحد ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_info_outline"
                app:tint="?attr/colorOnSurfaceVariant"
                android:alpha="0.6"
                android:contentDescription="@null"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tv_abuse_reporter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_abuse_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOutline" />
        </LinearLayout>

        <!-- ── أزرار الإجراءات (M3 styles) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- معالَج: Tonal (أقوى إيجابياً) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_abuse_resolve"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="معالَج"
                app:icon="@drawable/ic_done_all"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Material3.Button.TonalButton"
                app:cornerRadius="10dp" />

            <!-- تجاهل: Outlined (محايد) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_abuse_dismiss"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="تجاهل"
                app:icon="@drawable/ic_refresh"
                android:textSize="11sp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="10dp" />

            <!-- حذف: Text + colorError (أخطر إجراء) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_abuse_delete"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="حذف"
                app:icon="@drawable/ic_warning_outline"
                android:textSize="11sp"
                style="@style/Widget.Material3.Button.TextButton"
                app:iconTint="?attr/colorError"
                android:textColor="?attr/colorError"
                app:cornerRadius="10dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
