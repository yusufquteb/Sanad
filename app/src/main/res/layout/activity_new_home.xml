<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- ══ APP BAR ══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:liftOnScroll="false">

        <LinearLayout
            android:id="@+id/header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_home_header"
            android:paddingBottom="20dp"
            app:layout_scrollFlags="noScroll">

            <!-- Top row: greeting + chat + bell + avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أهلاً 👋"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="سند | Sanad"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Chat button -->
                <FrameLayout
                    android:id="@+id/btn_chats"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_chat"
                        android:padding="9dp"
                        android:background="@drawable/bg_icon_circle_white"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/badge_chats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:minWidth="16dp"
                        android:height="16dp"
                        android:gravity="center"
                        android:paddingHorizontal="3dp"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_badge_red"
                        android:visibility="gone"/>
                </FrameLayout>

                <!-- Notification bell -->
                <FrameLayout
                    android:id="@+id/btn_notifications"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_notification"
                        android:padding="9dp"
                        android:background="@drawable/bg_icon_circle_white"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/badge_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:minWidth="16dp"
                        android:height="16dp"
                        android:gravity="center"
                        android:paddingHorizontal="3dp"
                        android:textSize="8sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_badge_red"
                        android:visibility="gone"/>
                </FrameLayout>

                <!-- Avatar -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_user_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_person"
                    app:civ_border_width="2dp"
                    app:civ_border_color="#80FFFFFF"/>

            </LinearLayout>

            <!-- Search bar with bottom margin for spacing -->
            <LinearLayout
                android:id="@+id/search_bar"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_white"
                android:paddingHorizontal="14dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="18dp"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="14sp"
                    android:layout_marginEnd="10dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ابحث بالاسم أو المنطقة..."
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ SCROLLABLE CONTENT ══ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- TOP CARDS: Leaderboard + Success Stories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <!-- Leaderboard Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_leaderboard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#FFE0B2"
                    app:strokeWidth="1.5dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆"
                            android:textSize="32sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="المتصدرون"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1B2A6B"/>
                        <TextView
                            android:id="@+id/tv_leaderboard_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="10sp"
                            android:textColor="#F57F17"
                            android:textStyle="bold"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/bg_badge_orange"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Success Stories Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_success_stories"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:strokeColor="#C8E6C9"
                    app:strokeWidth="1.5dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅"
                            android:textSize="32sp"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="قصص النجاح"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1B2A6B"/>
                        <TextView
                            android:id="@+id/tv_success_stories_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="10sp"
                            android:textColor="#2E7D32"
                            android:textStyle="bold"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/bg_badge_green_light"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- STATS STRIP -->
            <LinearLayout
                android:id="@+id/stats_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E3EAF4"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">
                        <TextView
                            android:id="@+id/tv_stat_active"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1565C0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="حالة نشطة"
                            android:textSize="9sp"
                            android:textColor="#888888"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E3EAF4"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">
                        <TextView
                            android:id="@+id/tv_stat_found"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تم إيجادهم"
                            android:textSize="9sp"
                            android:textColor="#888888"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E3EAF4"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp">
                        <TextView
                            android:id="@+id/tv_stat_today"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#E65100"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="هذا الشهر"
                            android:textSize="9sp"
                            android:textColor="#888888"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- RECENT REPORTS HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="أحدث البلاغات"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1B2A6B"/>
                <TextView
                    android:id="@+id/btn_see_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عرض الكل"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- RECENT REPORTS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="6dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#DDE4EF">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_recent_reports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingVertical="4dp"
                    android:nestedScrollingEnabled="false"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hidden location text -->
            <TextView
                android:id="@+id/tv_location"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ EXTENDED FAB — أسفل يمين الصفحة وفوق الـ Navigation Bar ══ -->

    <!-- [إصلاح FoundPersonActivity] زر سريع: وجدت شخصاً -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_found_person"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="160dp"
        android:contentDescription="وجدت شخصاً"
        app:backgroundTint="?attr/colorSecondaryContainer"
        app:tint="?attr/colorOnSecondaryContainer"
        app:srcCompat="@drawable/ic_found"
        app:elevation="6dp"
        android:visibility="gone"/>

    <!-- [إصلاح FoundSightingActivity] زر سريع: رأيت شخصاً -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_sighting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="228dp"
        android:contentDescription="رأيت شخصاً"
        app:backgroundTint="?attr/colorTertiaryContainer"
        app:tint="?attr/colorOnTertiaryContainer"
        app:srcCompat="@drawable/ic_search_person"
        app:elevation="6dp"
        android:visibility="gone"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_report"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:text=" إضافة بلاغ"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:backgroundTint="#1565C0"
        app:elevation="8dp"
        app:icon="@drawable/ic_add_report"
        app:iconTint="#FFFFFF"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>