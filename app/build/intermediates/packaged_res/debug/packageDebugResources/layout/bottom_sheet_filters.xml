<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/md_outline_variant"
        android:alpha="0.5"/>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="تخصيص البحث"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/md_on_surface"
        android:layout_marginBottom="16dp"
        android:gravity="center"/>

    <!-- Governorate Filter -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="المحافظة"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="20dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_governorate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp"/>

    </HorizontalScrollView>

    <!-- Sort Order -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ترتيب حسب"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/radio_group_sort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/radio_smart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✨ ذكي (الأكثر صلة)"
            android:textSize="14sp"
            android:paddingVertical="8dp"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/radio_newest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 الأحدث أولاً"
            android:textSize="14sp"
            android:paddingVertical="8dp"/>

        <RadioButton
            android:id="@+id/radio_nearest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 الأقرب إليك"
            android:textSize="14sp"
            android:paddingVertical="8dp"/>

    </RadioGroup>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_reset_filters"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="إعادة ضبط"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:textColor="@color/md_error"/>

        <Button
            android:id="@+id/btn_apply_filters"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="تطبيق"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="@color/md_primary"/>

    </LinearLayout>

</LinearLayout>