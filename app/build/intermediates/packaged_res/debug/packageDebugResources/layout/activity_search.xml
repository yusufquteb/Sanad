<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <!-- ══ HEADER — Gradient أزرق ══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_header"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_search"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="🔍 بحث بالوجه"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ارفع صورة للبحث في قاعدة البيانات"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"
            android:paddingStart="72dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:layout_marginTop="-10dp"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ BODY ══ -->
    <androidx.core.widget.NestedScrollView
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="120dp">

            <!-- ══ منطقة رفع الصورة (dashed) ══ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#1565C0"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="#F0F7FF"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- معاينة الصورة المختارة (مخفية في البداية) -->
                    <ImageView
                        android:id="@+id/iv_search_photo"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_face_placeholder"
                        android:background="@color/md_surface_variant"
                        android:contentDescription="@null"
                        android:visibility="gone"/>

                    <!-- أيقونة الرفع (تُخفى عند اختيار صورة) -->
                    <TextView
                        android:id="@+id/tv_upload_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="52sp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ارفع صورة الشخص"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B2A6B"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أو التقط صورة الآن"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:layout_marginTop="4dp"
                        android:gravity="center"/>

                    <!-- معلومات الوجه المكتشف -->
                    <TextView
                        android:id="@+id/tv_face_detected"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/md_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:padding="8dp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"/>

                    <!-- أزرار الاختيار -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_gallery"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="🖼️ من المعرض"
                            android:textSize="13sp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="14dp"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_pick_camera"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:text="📷 الكاميرا"
                            android:textSize="13sp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:cornerRadius="14dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══ AI Chip ══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖 تعمل بالذكاء الاصطناعي"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:background="#E8F0FE"
                android:paddingHorizontal="14dp"
                android:paddingVertical="7dp"
                android:layout_marginBottom="16dp"/>

            <!-- حالة البحث -->
            <TextView
                android:id="@+id/tv_search_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اختر صورة للشخص المفقود للبدء"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginBottom="4dp"/>

            <!-- Progress -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:indeterminate="true"
                android:layout_marginBottom="12dp"
                app:indicatorColor="?attr/colorPrimary"
                app:trackColor="?attr/colorSurfaceVariant"/>

            <!-- زر البحث -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_search"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ابدأ البحث بالذكاء الاصطناعي"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"
                style="@style/Widget.Material3.Button"
                app:cornerRadius="24dp"/>

            <!-- ══ عنوان النتائج ══ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="نتائج مشابهة"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1B2A6B"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:id="@+id/tv_results_title"/>

            <!-- نتائج البحث -->
            <LinearLayout
                android:id="@+id/layout_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
