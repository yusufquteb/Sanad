<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- رأس الويدجت -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔍 آخر البلاغات"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_btn_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="عرض الكل ›"
            android:textColor="#AED6F1"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"/>
    </LinearLayout>

    <!-- عناوين الأعمدة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤 مفقود"
            android:textColor="#AED6F1"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:background="#44FFFFFF"
            android:layout_marginHorizontal="4dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✅ معثور عليه"
            android:textColor="#A9DFBF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <!-- فاصل -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="6dp"/>

    <!-- صف 1: مفقود + معثور -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- مفقود 1 -->
        <LinearLayout
            android:id="@+id/widget_row1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_name1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_addr1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_date1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AED6F1"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- فاصل عمودي -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="4dp"/>

        <!-- معثور 1 -->
        <LinearLayout
            android:id="@+id/widget_row_found1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <TextView
                android:id="@+id/widget_found_name1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#A9DFBF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_found_addr1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_found_date1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#A9DFBF"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- فاصل أفقي -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22FFFFFF"
        android:layout_marginVertical="4dp"/>

    <!-- صف 2: مفقود + معثور -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_row2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_name2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_addr2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_date2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AED6F1"
                android:textSize="9sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="4dp"/>

        <LinearLayout
            android:id="@+id/widget_row_found2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <TextView
                android:id="@+id/widget_found_name2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#A9DFBF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_found_addr2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_found_date2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#A9DFBF"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- فاصل أفقي -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22FFFFFF"
        android:layout_marginVertical="4dp"/>

    <!-- صف 3: مفقود + معثور -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/widget_row3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_name3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_addr3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_date3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AED6F1"
                android:textSize="9sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"
            android:layout_marginHorizontal="4dp"/>

        <LinearLayout
            android:id="@+id/widget_row_found3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="4dp">

            <TextView
                android:id="@+id/widget_found_name3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#A9DFBF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_found_addr3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBBBBB"
                android:textSize="10sp"
                android:maxLines="1"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/widget_found_date3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#A9DFBF"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
