<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingHorizontal="12dp"
    android:paddingVertical="3dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="260dp"
        android:background="@drawable/bg_bubble_received"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <!-- [1.3] صورة — تظهر فقط لو النوع image -->
        <ImageView
            android:id="@+id/iv_msg_image"
            android:layout_width="200dp"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="4dp"
            android:background="@color/md_surface_variant"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tv_msg_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/md_on_surface"
            android:lineSpacingExtra="2dp"/>

        <TextView
            android:id="@+id/tv_msg_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/md_on_surface_variant"
            android:layout_gravity="end"
            android:layout_marginTop="3dp"/>
    </LinearLayout>
</LinearLayout>
