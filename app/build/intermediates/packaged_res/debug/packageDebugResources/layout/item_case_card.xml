<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_case"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/md_surface"
    app:strokeColor="@color/md_outline_variant"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:contentDescription="بطاقة مفقود، اضغط للتفاصيل">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Photo -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/iv_case_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_face_placeholder"/>

            <!-- Gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom"/>

            <!-- Type badge top-start -->
            <TextView
                android:id="@+id/tv_case_type_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_gravity="top|start"
                android:text="مفقود"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_primary"
                android:background="@color/md_primary"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>

            <!-- Time badge top-end -->
            <TextView
                android:id="@+id/tv_case_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_gravity="top|end"
                android:textSize="10sp"
                android:textColor="@color/white"
                android:background="#88000000"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
        </FrameLayout>

        <!-- Info section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_case_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="مجهول"
                android:textColor="@color/md_on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tv_case_addr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/md_on_surface_variant"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="6dp"/>

            <!-- Chips row -->
            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:chipSpacingHorizontal="4dp"
                android:layout_marginBottom="6dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/tv_case_age"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="العمر: ؟"
                    android:textSize="10sp"
                    style="@style/Widget.Material3.Chip.Assist"
                    app:chipBackgroundColor="@color/md_surface_variant"
                    app:chipMinTouchTargetSize="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/tv_case_gender"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="النوع: ؟"
                    android:textSize="10sp"
                    style="@style/Widget.Material3.Chip.Assist"
                    app:chipBackgroundColor="@color/md_surface_variant"
                    app:chipMinTouchTargetSize="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_case_status"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="نشط"
                    android:textSize="10sp"
                    style="@style/Widget.Material3.Chip.Assist"
                    app:chipBackgroundColor="@color/md_secondary_container"
                    android:textColor="@color/md_on_secondary_container"
                    app:chipMinTouchTargetSize="0dp"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Smart Score badge (يظهر فقط في نتائج البحث الذكي) -->
            <TextView
                android:id="@+id/tv_smart_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="10sp"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_blue_light"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="6dp"
                android:text="⚡ 0%"/>

            <!-- Abuse report button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_comment_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💬 تعليق"
                    android:textSize="11sp"
                    android:textColor="#1565C0"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>
                <!-- زر المشاركة (Phase 6.4) -->
                <ImageView
                    android:id="@+id/btn_share_case"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_share"
                    android:contentDescription="شارك البلاغ"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/btn_report_abuse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ إبلاغ"
                    android:textSize="11sp"
                    android:textColor="@color/md_error"
                    android:paddingVertical="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
