<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_dash_report_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    android:layout_marginBottom="8dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Status color dot -->
        <View
            android:id="@+id/view_status_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_badge_orange"/>

        <!-- Person info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_dash_report_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/cairo"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_dash_report_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/cairo"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" · "
                    android:textSize="11sp"
                    android:textColor="?attr/colorOutline"/>

                <TextView
                    android:id="@+id/tv_dash_report_gov"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/cairo"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_dash_report_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="?attr/colorOutline"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/cairo"/>
        </LinearLayout>

        <!-- Open button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dash_open"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="فتح"
            android:textSize="11sp"
            android:paddingHorizontal="14dp"
            style="@style/Widget.Material3.Button.TonalButton"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
