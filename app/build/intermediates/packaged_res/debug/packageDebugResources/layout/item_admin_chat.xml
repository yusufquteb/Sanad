<?xml version="1.0" encoding="utf-8"?>
<!--
  item_admin_chat.xml — عنصر محادثة في لوحة الأدمن
  ✅ ?attr/ color tokens بدل @color/md_*
  ✅ Avatar دائرية تعرض الحرف الأول من اسم المستخدم
  ✅ Unread badge (رقم الرسائل الجديدة)
  ✅ صف العنوان: الاسم + الوقت
  ✅ صف المعاينة: آخر رسالة + badge العدد
  ملاحظة: AdminChatsActivity يجب أن يملأ tv_admin_chat_avatar بالحرف الأول
           ويتحكم في visibility لـ card_unread_badge عند count > 0
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_admin_chat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- ── Avatar دائرية ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="46dp"
            android:layout_height="46dp"
            app:cardCornerRadius="23dp"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">
            <TextView
                android:id="@+id/tv_admin_chat_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:text="؟" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ── عمود المحتوى ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- الصف الأول: الأسماء + الوقت -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_admin_chat_names"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="?attr/textAppearanceTitleSmall"
                    android:textColor="?attr/colorOnSurface"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_admin_chat_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorOutline" />
            </LinearLayout>

            <!-- الصف الثاني: آخر رسالة + badge عدد الرسائل -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_admin_chat_last_msg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Badge عدد الرسائل — يُخفى عند count == 0 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_unread_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="?attr/colorPrimary"
                    app:cardElevation="0dp"
                    android:layout_marginStart="8dp"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/tv_admin_chat_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="20dp"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:gravity="center"
                        style="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnPrimary"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
