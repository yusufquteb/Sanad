<?xml version="1.0" encoding="utf-8"?>
<!--
    item_match_comparison.xml
    [إصلاح 3.1] Layout مخصص لعرض التطابقات في AdminActivity
    يعرض صورتين جنب بعض + نسبة التطابق + أزرار التأكيد/الرفض
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_match_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorPrimary"
    app:strokeWidth="1dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header: عنوان التطابق -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔗 تطابق محتمل"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                style="?attr/textAppearanceTitleSmall"/>

            <!-- نسبة التطابق badge -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_match_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                app:chipBackgroundColor="?attr/colorPrimaryContainer"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textSize="13sp"
                android:textStyle="bold"
                app:chipCornerRadius="20dp"/>
        </LinearLayout>

        <!-- الصورتان جنب بعض -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- صورة المفقود (يسار) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <ImageView
                    android:id="@+id/iv_match_report"
                    android:layout_width="110dp"
                    android:layout_height="130dp"
                    android:scaleType="centerCrop"
                    android:background="?attr/colorSurfaceVariant"
                    android:contentDescription="@null"
                    app:shapeAppearanceOverride="@style/Shape.M3.Medium"/>

                <TextView
                    android:id="@+id/tv_match_report_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المفقود"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_match_report_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: ---"
                    android:textSize="9sp"
                    android:textColor="?attr/colorOutline"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- سهم وسطي -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↔"
                    android:textSize="24sp"
                    android:textColor="?attr/colorPrimary"/>

                <TextView
                    android:id="@+id/tv_match_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="قيد المراجعة"
                    android:textSize="9sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- صورة الموجود (يمين) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="8dp">

                <ImageView
                    android:id="@+id/iv_match_found"
                    android:layout_width="110dp"
                    android:layout_height="130dp"
                    android:scaleType="centerCrop"
                    android:background="?attr/colorSurfaceVariant"
                    android:contentDescription="@null"
                    app:shapeAppearanceOverride="@style/Shape.M3.Medium"/>

                <TextView
                    android:id="@+id/tv_match_found_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الموجود"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_match_found_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: ---"
                    android:textSize="9sp"
                    android:textColor="?attr/colorOutline"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- وقت التطابق -->
        <TextView
            android:id="@+id/tv_match_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="11sp"
            android:textColor="?attr/colorOutline"
            android:layout_marginTop="10dp"
            android:gravity="center"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:layout_marginVertical="10dp"/>

        <!-- أزرار التأكيد والرفض -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm_match"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="✅ تأكيد التطابق"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                style="@style/Widget.Material3.Button.TonalButton"
                app:backgroundTint="?attr/colorPrimaryContainer"
                android:textColor="?attr/colorOnPrimaryContainer"
                app:cornerRadius="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reject_match"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="❌ رفض"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.TonalButton"
                app:backgroundTint="@color/md_error_container"
                android:textColor="@color/md_error"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
