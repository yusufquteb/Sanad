<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_match_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- ══ Header: نسبة التطابق + زر مشاركة ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F0F4FF"
            android:paddingHorizontal="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔗 تطابق محتمل"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1565C0"/>

            <TextView
                android:id="@+id/chip_match_score"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:minWidth="60dp"
                android:text="—%"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#1565C0"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp"/>

            <!-- زر مشاركة كارد التطابق كصورة -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share_match"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                app:icon="@drawable/ic_share"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:strokeColor="#1565C0"
                app:cornerRadius="10dp"
                android:text=""
                android:contentDescription="مشاركة"/>
        </LinearLayout>

        <!-- شريط التقدم -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_match"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:max="100"
            android:progress="0"
            app:trackCornerRadius="0dp"
            app:trackColor="#E3ECFF"
            app:indicatorColor="#1565C0"/>

        <!-- ══ صورة المفقود الكبيرة + معلوماته ══ -->
        <LinearLayout
            android:id="@+id/row_missing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F8FAFF"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Badge نوع البلاغ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المفقود"
                android:textSize="10sp"
                android:textColor="#1565C0"
                android:background="#E3ECFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="8dp"/>

            <!-- صورة رئيسية + اسم وتفاصيل -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <!-- الصورة الرئيسية للمفقود -->
                <ImageView
                    android:id="@+id/iv_match_report"
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:scaleType="centerCrop"
                    android:background="#E3ECFF"
                    android:contentDescription="@null"
                    android:layout_marginEnd="12dp"/>

                <!-- البيانات -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_match_report_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B2A6B"
                        android:maxLines="2"/>

                    <TextView
                        android:id="@+id/tv_match_report_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="11sp"
                        android:textColor="#888"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="6dp"/>

                    <!-- العمر والجنس -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:id="@+id/tv_match_report_age"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#555"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:id="@+id/tv_match_report_gender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#555"/>
                    </LinearLayout>

                    <!-- العنوان -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_location_on"
                            app:tint="#1565C0"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/tv_match_report_addr"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="11sp"
                            android:textColor="#555"
                            android:maxLines="2"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <!-- رقم التواصل -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_person_outline"
                            app:tint="#1565C0"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/tv_match_report_phone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="11sp"
                            android:textColor="#1565C0"
                            android:maxLines="1"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- صور إضافية المفقود (horizontal strip) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/ll_report_extra_photos"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ══ فاصل مع أيقونة ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="#E3ECFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  🔗  " android:textSize="16sp" android:textColor="#1565C0"/>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="#E3ECFF"/>
        </LinearLayout>

        <!-- ══ صورة المعثور الكبيرة + معلوماته ══ -->
        <LinearLayout
            android:id="@+id/row_found"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5FFF7"
            android:paddingHorizontal="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المعثور"
                android:textSize="10sp"
                android:textColor="#2E7D32"
                android:background="#C8E6C9"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="8dp"/>

            <!-- صورة رئيسية + بيانات -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <ImageView
                    android:id="@+id/iv_match_found"
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:scaleType="centerCrop"
                    android:background="#D4EDDA"
                    android:contentDescription="@null"
                    android:layout_marginEnd="12dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_match_found_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1B4332"
                        android:maxLines="2"/>

                    <TextView
                        android:id="@+id/tv_match_found_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="11sp"
                        android:textColor="#888"
                        android:fontFamily="monospace"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="6dp"/>

                    <!-- العمر والجنس -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:id="@+id/tv_match_found_age"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#555"
                            android:layout_marginEnd="10dp"/>
                        <TextView
                            android:id="@+id/tv_match_found_gender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#555"/>
                    </LinearLayout>

                    <!-- العنوان -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_location_on"
                            app:tint="#2E7D32"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/tv_match_found_addr"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="11sp"
                            android:textColor="#555"
                            android:maxLines="2"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <!-- التواصل -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_person_outline"
                            app:tint="#2E7D32"
                            android:layout_marginEnd="4dp"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/tv_match_found_phone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="11sp"
                            android:textColor="#2E7D32"
                            android:maxLines="1"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- صور إضافية المعثور -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/ll_found_extra_photos"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ══ التاريخ والحالة ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tv_match_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textSize="11sp"
                android:textColor="#AAA"/>

            <TextView
                android:id="@+id/tv_match_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="قيد المراجعة"
                android:textSize="11sp"
                android:textColor="#F57C00"
                android:background="#FFF3E0"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- ══ أزرار الإجراءات ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reject"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="❌ رفض"
                android:textSize="13sp"
                android:textColor="#C62828"
                android:backgroundTint="#FFEBEE"
                style="@style/Widget.Material3.Button.TextButton"
                app:cornerRadius="0dp"
                app:strokeWidth="0dp"/>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="#F0F0F0"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_approve"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="✅ تأكيد التطابق"
                android:textSize="13sp"
                android:textColor="#1565C0"
                android:backgroundTint="#E8F0FE"
                style="@style/Widget.Material3.Button.TextButton"
                app:cornerRadius="0dp"
                app:strokeWidth="0dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
